<!--pages/add-student/add-student.wxml-->
<view class="page">
  <view class="card">
    <!-- 基本信息 -->
    <view class="form-group">
      <text class="form-label">学生姓名 *</text>
      <input class="form-input" placeholder="请输入姓名" value="{{name}}" bindinput="onNameInput" />
    </view>

    <view class="form-group">
      <text class="form-label">联系电话</text>
      <input class="form-input" placeholder="请输入电话" value="{{phone}}" bindinput="onPhoneInput" type="number" />
    </view>

    <view class="form-group">
      <text class="form-label">年龄</text>
      <input class="form-input" placeholder="请输入年龄" value="{{age}}" bindinput="onAgeInput" type="number" />
    </view>

    <!-- 课时费选择 -->
    <view class="form-group">
      <text class="form-label">课时费（元/节）</text>
      <view class="capsule-group">
        <view
          class="capsule-btn {{feePerLesson === item ? 'active' : ''}}"
          wx:for="{{feeOptions}}"
          wx:key="*this"
          data-fee="{{item}}"
          bindtap="onFeeSelect"
        >
          ¥{{item}}
        </view>
      </view>
    </view>

    <!-- 项目多选 -->
    <view class="form-group">
      <text class="form-label">课程项目</text>
      <view class="capsule-group">
        <view
          class="capsule-btn {{projects.indexOf(item) > -1 ? 'active' : ''}}"
          wx:for="{{projectOptions}}"
          wx:key="*this"
          data-project="{{item}}"
          bindtap="onProjectToggle"
        >
          {{item}}
        </view>
      </view>
    </view>

    <!-- 每周上课日 -->
    <view class="form-group">
      <text class="form-label">每周上课日</text>
      <view class="capsule-group">
        <view
          class="capsule-btn {{scheduleDays.indexOf(item.value) > -1 ? 'active' : ''}}"
          wx:for="{{weekDays}}"
          wx:key="value"
          data-day="{{item.value}}"
          bindtap="onDayToggle"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 已购课时 -->
    <view class="form-group">
      <text class="form-label">已购课时数</text>
      <input class="form-input" placeholder="0" value="{{purchasedLessons}}" bindinput="onPurchasedInput" type="number" />
    </view>

    <!-- 备注 -->
    <view class="form-group">
      <text class="form-label">备注</text>
      <textarea class="form-textarea" placeholder="选填" value="{{notes}}" bindinput="onNotesInput" />
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="btn-area">
    <button class="primary-btn" bindtap="onSave">{{isEdit ? '保存修改' : '添加学生'}}</button>
  </view>
</view>
