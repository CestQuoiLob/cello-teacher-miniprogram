/* pages/index/index.wxss */
.page {
  padding-bottom: 160rpx;
}

.stats-row {
  display: flex;
  padding: 20rpx 16rpx;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  padding: 0 24rpx;
  gap: 20rpx;
  margin-bottom: 8rpx;
}

.quick-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx 0;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(139, 105, 20, 0.06);
}

.quick-icon {
  font-size: 32rpx;
}

.quick-text {
  font-size: 26rpx;
  color: #8B6914;
  font-weight: 500;
}

/* 列表标题 */
.section-header {
  display: flex;
  align-items: baseline;
  padding: 24rpx 28rpx 0;
  gap: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
}

.section-count {
  font-size: 22rpx;
  color: #999999;
}

.student-card {
  position: relative;
}

.student-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.student-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.student-fee {
  font-size: 26rpx;
  color: #8B6914;
  font-weight: 500;
}

.student-tags {
  margin-bottom: 12rpx;
}

.student-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.student-schedule {
  font-size: 24rpx;
  color: #999999;
}

.student-schedule .label {
  color: #999999;
}

.student-schedule .value {
  color: #666666;
}

.student-remaining {
  font-size: 24rpx;
  color: #666666;
}

.student-remaining .num {
  font-weight: bold;
  color: #27AE60;
}

.student-remaining .num.low {
  color: #E67E22;
}

.student-remaining.exhausted .exhausted-text {
  color: #E74C3C;
  font-weight: 500;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 80rpx 40rpx;
  color: #999999;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999999;
}
