<!--pages/settings/settings.wxml-->
<view class="page">
  <view class="settings-group">
    <view class="settings-item" bindtap="onExportData">
      <view class="item-left">
        <view class="item-icon">📤</view>
        <view class="item-text">导出数据</view>
      </view>
      <view class="item-arrow">›</view>
    </view>

    <view class="settings-item danger" bindtap="onClearData">
      <view class="item-left">
        <view class="item-icon">🗑️</view>
        <view class="item-text">清除所有数据</view>
      </view>
      <view class="item-arrow">›</view>
    </view>
  </view>

  <view class="settings-group">
    <view class="settings-item" bindtap="onAbout">
      <view class="item-left">
        <view class="item-icon">ℹ️</view>
        <view class="item-text">关于</view>
      </view>
      <view class="item-arrow">›</view>
    </view>
  </view>

  <view class="version-info">大提琴教学管理 v1.0.0</view>

  <!-- 清除确认弹窗 -->
  <view class="modal-mask" wx:if="{{showClearConfirm}}" bindtap="onCancelClear">
    <view class="modal-content" catchtap="">
      <view class="modal-title">⚠️ 危险操作</view>
      <view class="modal-text">确定要清除所有学生数据和上课记录吗？此操作不可恢复！</view>
      <view class="modal-buttons">
        <view class="modal-btn cancel" bindtap="onCancelClear">取消</view>
        <view class="modal-btn confirm" style="background-color:#E74C3C" bindtap="onConfirmClear">确认清除</view>
      </view>
    </view>
  </view>
</view>
