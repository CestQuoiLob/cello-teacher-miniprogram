/* pages/calendar-view/calendar-view.wxss */
.page {
  padding-bottom: 40rpx;
}

.month-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 40rpx;
  background-color: #FFFFFF;
}

.nav-arrow {
  font-size: 32rpx;
  color: #8B6914;
  padding: 16rpx;
}

.month-label {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.filter-bar {
  padding: 12rpx 24rpx;
}

.filter-btn {
  font-size: 26rpx;
  color: #8B6914;
  padding: 8rpx 16rpx;
  background-color: #FFFFFF;
  border-radius: 8rpx;
  display: inline-block;
}

.calendar {
  padding: 16rpx;
}

.week-header {
  display: flex;
  margin-bottom: 12rpx;
}

.week-cell {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #999999;
  padding: 8rpx 0;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
}

.day-cell {
  width: 14.285%;
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.day-cell.empty {
  background: transparent;
}

.day-cell.has-record {
  cursor: pointer;
}

.day-cell.selected {
  background-color: rgba(139, 105, 20, 0.15);
  border-radius: 12rpx;
}

.day-num {
  font-size: 28rpx;
  color: #333333;
}

.day-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background-color: #8B6914;
  position: absolute;
  bottom: 8rpx;
}

.records-section {
  padding: 0 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333333;
  margin: 20rpx 0;
}

.record-card {
  position: relative;
}

.record-card.adjusted {
  background-color: #FFFBF0;
  border-left: 6rpx solid #FFE69C;
}

.record-time {
  font-size: 26rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.record-project {
  display: flex;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.record-student {
  font-size: 24rpx;
  color: #8B6914;
  margin-bottom: 4rpx;
}

.record-notes {
  font-size: 24rpx;
  color: #999999;
}

.pagination {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 24rpx 0;
  gap: 24rpx;
}

.page-btn {
  font-size: 26rpx;
  color: #8B6914;
  padding: 8rpx 20rpx;
  background-color: #FFFFFF;
  border-radius: 8rpx;
  border: 1rpx solid #8B6914;
}

.page-btn.disabled {
  color: #CCCCCC;
  border-color: #CCCCCC;
}

.page-info {
  font-size: 26rpx;
  color: #666666;
}
