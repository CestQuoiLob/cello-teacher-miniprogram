<!--pages/add-record/add-record.wxml-->
<view class="page">
  <view class="card">
    <!-- 选择学生 -->
    <view class="form-group">
      <text class="form-label">选择学生 *</text>
      <picker mode="selector" range="{{students}}" range-key="name" value="{{studentIndex}}" bindchange="onStudentChange">
        <view class="picker-item {{studentIndex === -1 ? 'placeholder' : ''}}">
          {{studentIndex === -1 ? '请选择学生' : students[studentIndex].name}}
        </view>
      </picker>
    </view>

    <!-- 日期 -->
    <view class="form-group">
      <text class="form-label">上课日期</text>
      <picker mode="date" value="{{date}}" bindchange="onDateChange">
        <view class="picker-item">{{date}}</view>
      </picker>
    </view>

    <!-- 时间 -->
    <view class="form-group">
      <text class="form-label">上课时间</text>
      <picker mode="time" value="{{time}}" bindchange="onTimeChange">
        <view class="picker-item">{{time}}</view>
      </picker>
    </view>

    <!-- 课程时长 -->
    <view class="form-group">
      <text class="form-label">课程时长</text>
      <view class="capsule-group">
        <view
          class="capsule-btn {{duration === item.value ? 'active' : ''}}"
          wx:for="{{durationOptions}}"
          wx:key="value"
          data-duration="{{item.value}}"
          bindtap="onDurationSelect"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 课程项目 -->
    <view class="form-group">
      <text class="form-label">课程项目 *</text>
      <view class="capsule-group">
        <view
          class="capsule-btn {{project === item ? 'active' : ''}}"
          wx:for="{{projectOptions}}"
          wx:key="*this"
          data-project="{{item}}"
          bindtap="onProjectSelect"
        >
          {{item}}
        </view>
      </view>
    </view>

    <!-- 是否调课 -->
    <view class="form-group">
      <view class="checkbox-row">
        <checkbox-group bindchange="onAdjustedChange">
          <label>
            <checkbox value="adjusted" checked="{{isAdjusted}}" color="#8B6914" />
            <text class="checkbox-label">临时调课</text>
          </label>
        </checkbox-group>
      </view>
    </view>

    <!-- 原日期（调课时） -->
    <view class="form-group" wx:if="{{isAdjusted}}">
      <text class="form-label">原上课日期</text>
      <picker mode="date" value="{{originalDate}}" bindchange="onOriginalDateChange">
        <view class="picker-item">{{originalDate || '请选择原日期'}}</view>
      </picker>
    </view>

    <!-- 备注 -->
    <view class="form-group">
      <text class="form-label">备注</text>
      <textarea class="form-textarea" placeholder="选填" value="{{notes}}" bindinput="onNotesInput" />
    </view>
  </view>

  <!-- 保存按钮 -->
  <view class="btn-area">
    <button class="primary-btn" bindtap="onSave">{{isEdit ? '保存修改' : '添加记录'}}</button>
  </view>
</view>
